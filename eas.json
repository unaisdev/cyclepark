{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_BUILD_TYPE": "debug"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "pre",
        "APP_BUILD_TYPE": "release"
      }
    },
    "production": {
      "env": {
        "APP_BUILD_TYPE": "release"
      }
    }
  }
}
