{
  "expo": {
    "name": "CyclePark",
    "slug": "ciclepark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyD_At6XWhj78Q2j7Gz9KHJzNdo1ygMHA6Q"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["com.android.vending.BILLING"],
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ciclepark",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD_At6XWhj78Q2j7Gz9KHJzNdo1ygMHA6Q"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "react-native-edge-to-edge/app.plugin.js",
      "react-native-iap/plugin",
      "expo-localization",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CiclePark usa tu ubicación para mostrarte en el mapa y encontrar aparcamientos cercanos."
        }
      ]
    ]
  }
}
